-- ══════════════════════════════════════════════
--  MediRecord Database Schema (NaCl / TweetNaCl)
-- ══════════════════════════════════════════════

-- ─── users ──────────────────────────────────
CREATE TABLE IF NOT EXISTS users (
  id                         INT AUTO_INCREMENT PRIMARY KEY,
  email                      VARCHAR(255) NOT NULL UNIQUE,
  password_hash              VARCHAR(255) NOT NULL,
  role                       VARCHAR(20)  NOT NULL DEFAULT 'patient',
  nacl_public_key            TEXT         DEFAULT NULL,
  encrypted_nacl_private_key TEXT         DEFAULT NULL,
  nacl_key_iv                VARCHAR(64)  DEFAULT NULL,
  nacl_key_auth_tag          VARCHAR(64)  DEFAULT NULL,
  ethereum_address           VARCHAR(42)  DEFAULT NULL,
  created_at                 TIMESTAMP    DEFAULT CURRENT_TIMESTAMP
);

-- ─── encrypted_keys ─────────────────────────
CREATE TABLE IF NOT EXISTS encrypted_keys (
  id                         INT AUTO_INCREMENT PRIMARY KEY,
  cid                        VARCHAR(255) NOT NULL,
  user_address               VARCHAR(255) NOT NULL,
  encrypted_aes_key          TEXT         NOT NULL,
  nonce                      VARCHAR(64)  DEFAULT NULL,
  sender_address             VARCHAR(255) DEFAULT NULL,
  created_at                 TIMESTAMP    DEFAULT CURRENT_TIMESTAMP,
  UNIQUE KEY unique_cid_user (cid, user_address)
);


-- ─── access_requests ────────────────────────
CREATE TABLE IF NOT EXISTS access_requests (
  id              INT NOT NULL AUTO_INCREMENT PRIMARY KEY,
  patient_address VARCHAR(255) NOT NULL,
  doctor_address  VARCHAR(255) NOT NULL,
  operation       VARCHAR(100) NOT NULL,
  purpose         VARCHAR(255) NOT NULL,
  status          ENUM('pending','approved','rejected') DEFAULT 'pending',
  created_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
